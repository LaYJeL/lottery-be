# Admin Credentials (Master Realm)
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=your_admin_password_here

# Lottery Database Credentials (App DB)
POSTGRES_USER=lottery_user
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=lottery_db

# Keycloak Database Credentials (Internal DB)
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=your_keycloak_db_password_here
KC_DB_NAME=keycloak
KC_DB_URL=jdbc:postgresql://keycloak-db:5432/keycloak

# Backend Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/lottery_db
# Public URL for Token Validation (Must match what the Frontend sees/Token 'iss' claim)
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:8080/realms/lottery
# Internal URL for Backend to fetch Keys (Docker-to-Docker)
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://keycloak:8080/realms/lottery/protocol/openid-connect/certs

# Keycloak Admin Client Configuration
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=lottery
KEYCLOAK_RESOURCE=lottery-backend
KEYCLOAK_CREDENTIALS_SECRET=your_keycloak_client_secret_here

# CORS Configuration
CORS_ALLOWED_ORIGIN=http://localhost:5173
